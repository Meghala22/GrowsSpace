{
  "name": "growspace-booking-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "dev:full": "netlify dev",
    "build": "tsc --noEmit && vite build --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "db:check": "node backend/scripts/db-check.mjs",
    "db:migrate": "node backend/scripts/db-migrate.mjs",
    "db:seed": "node backend/scripts/db-seed.mjs",
    "db:seed:demo-slots": "node backend/scripts/db-seed-demo-slots.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:seed:demo-slots",
    "promote:admin": "node backend/scripts/promote-admin.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@netlify/functions": "^4.2.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "netlify-cli": "^23.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
